# Generated experiment outputs
# ------------------------------------------------------------
outputs/*
*.log

# Keep selected output folder structure
!outputs/.gitkeep
!outputs/practical-exercises/
!outputs/practical-exercises/*/
!outputs/practical-exercises/*/.gitkeep


# ------------------------------------------------------------
# Data policy
# ------------------------------------------------------------
# Keep small curated datasets if intentionally committed.
# Ignore large/raw/local datasets by default.
data/raw/
data/external/
data/tmp/
data/cache/

# Keep folder structure if needed
!data/.gitkeep


# ------------------------------------------------------------
# Experiment workspace
# ------------------------------------------------------------
experiments/tmp/
experiments/cache/
experiments/runs/

!experiments/.gitkeep


# ------------------------------------------------------------
# Output workspace
# ------------------------------------------------------------
